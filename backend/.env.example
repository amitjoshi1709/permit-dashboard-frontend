# ── Supabase ─────────────────────────────────────────────────────────
# Find these in your Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Redis (Celery message broker + job status storage) ───────────────
# Default works if running Redis locally via Docker:
#   docker run -d -p 6379:6379 redis
REDIS_URL=redis://localhost:6379/0

# ── CAPTCHA Mode ─────────────────────────────────────────────────────
# "terminal"  → pauses in the Celery terminal, press ENTER after solving (local dev)
# "dashboard" → sets status to waiting_captcha, waits for frontend signal (production)
CAPTCHA_MODE=terminal

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
